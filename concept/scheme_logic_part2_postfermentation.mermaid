flowchart TB
    %% ═══════════════════════════════════════════════════════════
    %% ЧАСТИНА 2: ПОСТФЕРМЕНТАЦІЯ — ВІД КІНЦЯ БРОДІННЯ ДО РОЗЛИВУ
    %% Секції 15-22 (Гілки А, Б, В)
    %% ═══════════════════════════════════════════════════════════

    %% ══════ 15. РОЗГАЛУЖЕННЯ ЗА ТИПОМ ВИНА ══════
    POST_DONE["Після первинного бродіння<br>#40;з частини 1#41;"] --> POST_TYPE{"Тип вина"}
    POST_TYPE -- Тихе --> POST_SWEET{"Солодкість вина"}
    POST_TYPE -- Ігристе --> SPARK_METHOD{"Метод<br>виробництва"}
    POST_SWEET -- Сухе --> MLF_COLOR
    POST_SWEET -- "Не сухе" --> NS_START["Постферментація:<br>тихе не-сухе вино"]

    %% ═══════════════════════════════════════════
    %% ══  ГІЛКА А: ТИХЕ СУХЕ ВИНО             ══
    %% ═══════════════════════════════════════════

    %% ══════ 15А. МЛБ (МАЛОЛАКТИЧНЕ БРОДІННЯ) ══════
    MLF_COLOR{"Сировина<br>і колір"}

    %% БІЛЕ / БЛАН ДЕ НУАР — МЛБ
    MLF_COLOR -- Біле --> MLF_W{"Тіло >= 60<br>або oxidation >= 50?"}
    MLF_COLOR -- "Блан де нуар" --> MLF_W
    MLF_W -- Так --> MLF_W_YES["МЛБ: так<br>інокуляція або спонтанне<br>температура 18-22°C"]
    MLF_W -- Ні --> MLF_W_AROM{"Ароматична<br>інтенсивність >= 60?"}
    MLF_W_AROM -- Так --> MLF_W_NO["МЛБ: ні<br>зберегти свіжість і кислотність<br>SO2 одразу після бродіння"]
    MLF_W_AROM -- Ні --> MLF_W_OPT["МЛБ: необов'язково<br>часткове або повне<br>за результатами дегустації"]

    %% РОЖЕВЕ — МЛБ
    MLF_COLOR -- Рожеве --> MLF_ROSE["МЛБ: ні<br>зберегти свіжість і кислотність<br>SO2 після бродіння"]

    %% ЧЕРВОНЕ — МЛБ
    MLF_COLOR -- Червоне --> MLF_RED{"Спонтанне<br>чи інокуляція?"}
    MLF_RED -- Спонтанне --> MLF_RED_SP["МЛБ: спонтанне<br>температура 18-22°C<br>контроль яблучної кислоти<br>тривалість 2-8 тижнів"]
    MLF_RED -- Інокуляція --> MLF_RED_IN["МЛБ: інокуляція<br>Oenococcus oeni<br>температура 18-22°C<br>тривалість 2-4 тижні"]

    %% ПОМАРАНЧЕВЕ — МЛБ
    MLF_COLOR -- Помаранчеве --> MLF_O["МЛБ: спонтанне<br>зазвичай проходить<br>під час або після АБ<br>контроль яблучної кислоти"]

    %% ══════ 16. ПЕРШЕ ЗНЯТТЯ З ОСАДУ + SO2 ══════

    %% БІЛЕ
    MLF_W_YES --> RACK_W["Зняття з осаду:<br>після завершення МЛБ<br>SO2 25-35 мг/л вільного"]
    MLF_W_NO --> RACK_W_EARLY["Зняття з осаду:<br>SO2 30-40 мг/л вільного<br>одразу після АБ"]
    MLF_W_OPT --> RACK_W

    %% РОЖЕВЕ
    MLF_ROSE --> RACK_ROSE["Зняття з осаду:<br>SO2 30-40 мг/л вільного<br>одразу після АБ"]

    %% ЧЕРВОНЕ
    MLF_RED_SP --> RACK_RED["Зняття з осаду:<br>після завершення МЛБ<br>SO2 20-30 мг/л вільного"]
    MLF_RED_IN --> RACK_RED

    %% ПОМАРАНЧЕВЕ
    MLF_O --> RACK_O["Зняття з осаду:<br>SO2 0-20 мг/л<br>або без SO2<br>мінімальне втручання"]

    %% ══════ 17. ВИТРИМКА ══════

    %% БІЛЕ — витримка
    RACK_W --> AGE_W{"Oxidation >= 50<br>і тіло >= 60?"}
    RACK_W_EARLY --> AGE_W
    AGE_W -- Так --> AGE_W_OAK["Витримка: дуб<br>барік 225л або 500л<br>новий або б/в<br>4-12 місяців"]
    AGE_W -- Ні --> AGE_W_BODY{"Тіло >= 50?"}
    AGE_W_BODY -- Так --> AGE_W_LARGE["Витримка: великий дуб<br>або акація<br>4-8 місяців"]
    AGE_W_BODY -- Ні --> AGE_W_STEEL["Витримка: сталь<br>інертне середовище<br>2-6 місяців"]

    %% РОЖЕВЕ — витримка
    RACK_ROSE --> AGE_ROSE["Витримка: сталь<br>1-3 місяці<br>зберегти свіжість"]

    %% ЧЕРВОНЕ — витримка
    RACK_RED --> AGE_RED_TAN{"Танінність >= 60<br>і тіло >= 60?"}
    AGE_RED_TAN -- Так --> AGE_RED_NEW["Витримка: новий дуб барік<br>225л<br>12-24 місяці"]
    AGE_RED_TAN -- Ні --> AGE_RED_TAN2{"Танінність >= 50?"}
    AGE_RED_TAN2 -- Так --> AGE_RED_USED["Витримка: б/в дуб барік<br>225л<br>6-18 місяців"]
    AGE_RED_TAN2 -- Ні --> AGE_RED_BODY{"Тіло >= 50?"}
    AGE_RED_BODY -- Так --> AGE_RED_LARGE["Витримка: великий дуб<br>500-2000л<br>6-12 місяців"]
    AGE_RED_BODY -- Ні --> AGE_RED_AROM{"Ароматична<br>інтенсивність >= 60?"}
    AGE_RED_AROM -- Так --> AGE_RED_LT_OAK["Витримка: б/в дуб<br>або великий дуб<br>6-12 місяців"]
    AGE_RED_AROM -- Ні --> AGE_RED_STEEL["Витримка: сталь<br>2-4 місяці<br>або мінімальний дуб"]

    %% ПОМАРАНЧЕВЕ — витримка
    RACK_O --> AGE_O{"Oxidation >= 50?"}
    AGE_O -- Так --> AGE_O_AMPH["Витримка: амфора<br>або великий дуб<br>3-12 місяців"]
    AGE_O -- Ні --> AGE_O_STEEL["Витримка: сталь<br>або амфора<br>3-6 місяців"]

    %% ══════ 18. БАТОНАЖ ══════

    %% БІЛЕ — батонаж
    AGE_W_OAK --> BAT_W{"Тіло >= 50?"}
    AGE_W_LARGE --> BAT_W
    AGE_W_STEEL --> BAT_W_TH{"Тіолові/терпенові >= 50?"}
    BAT_W_TH -- Так --> BAT_W_NO["Без батонажу:<br>редуктивна витримка<br>зберегти тіоли"]
    BAT_W_TH -- Ні --> BAT_W_LIGHT["Легкий батонаж:<br>1 раз/тиждень<br>1-2 місяці"]
    BAT_W -- Так --> BAT_W_FULL["Батонаж:<br>1-2 рази/тиждень<br>2-6 місяців<br>складність, текстура"]
    BAT_W -- Ні --> BAT_W_LIGHT

    %% РОЖЕВЕ — батонаж
    AGE_ROSE --> BAT_ROSE["Без батонажу<br>або мінімальний"]

    %% ЧЕРВОНЕ — графік зняття з осаду
    AGE_RED_NEW --> BAT_RED["Зняття з осаду<br>кожні 3-4 місяці<br>контроль SO2"]
    AGE_RED_USED --> BAT_RED
    AGE_RED_LARGE --> BAT_RED
    AGE_RED_LT_OAK --> BAT_RED
    AGE_RED_STEEL --> BAT_RED_MIN["Зняття з осаду<br>1-2 рази за витримку"]

    %% ПОМАРАНЧЕВЕ — батонаж
    AGE_O_AMPH --> BAT_O["Батонаж:<br>за бажанням<br>1 раз/тиждень або рідше"]
    AGE_O_STEEL --> BAT_O

    %% ══════ 19. ОСВІТЛЕННЯ ══════

    %% БІЛЕ — освітлення
    BAT_W_FULL --> CLAR_W{"Оклейка<br>потрібна?"}
    BAT_W_NO --> CLAR_W
    BAT_W_LIGHT --> CLAR_W

    CLAR_W -- Так --> CLAR_W_TYPE{"Основна<br>каламуть"}
    CLAR_W -- Ні --> CLAR_W_SELF["Самоосвітлення:<br>відстоювання 2-4 тижні<br>зняття з осаду"]

    CLAR_W_TYPE -- "Білкова каламуть" --> CLAR_W_BENT["Бентоніт:<br>20-60 г/гл<br>видалення білків + освітлення"]
    CLAR_W_TYPE -- "Фенольна каламуть" --> CLAR_W_PVPP["PVPP 20-40 г/гл<br>+ бентоніт 20-40 г/гл"]
    CLAR_W_TYPE -- "Окислені феноли" --> CLAR_W_CAS["Казеїн 5-20 г/гл<br>або активоване вугілля<br>+ бентоніт 20-40 г/гл"]

    %% РОЖЕВЕ — освітлення
    BAT_ROSE --> CLAR_ROSE{"Оклейка<br>потрібна?"}
    CLAR_ROSE -- Так --> CLAR_ROSE_BENT["Бентоніт 20-50 г/гл<br>+ казеїн 5-15 г/гл<br>за потреби корекції кольору"]
    CLAR_ROSE -- Ні --> CLAR_ROSE_SELF["Самоосвітлення:<br>відстоювання 2-3 тижні"]

    %% ЧЕРВОНЕ — освітлення
    BAT_RED --> CLAR_RED{"Оклейка<br>потрібна?"}
    BAT_RED_MIN --> CLAR_RED
    CLAR_RED -- Так --> CLAR_RED_TYPE{"Метод оклейки"}
    CLAR_RED -- Ні --> CLAR_RED_SKIP["Без оклейки:<br>самоосвітлення"]
    CLAR_RED_TYPE -- "Яєчний білок" --> CLAR_RED_EGG["Яєчний білок:<br>3-5 шт/барік<br>пом'якшення танінів<br>зняття з осаду через 2-3 тижні"]
    CLAR_RED_TYPE -- Желатин --> CLAR_RED_GEL["Желатин:<br>5-10 г/гл<br>видалення грубих танінів<br>зняття з осаду через 1-2 тижні"]
    CLAR_RED_TYPE -- PVPP --> CLAR_RED_PVPP["PVPP:<br>20-40 г/гл<br>видалення окислених фенолів"]

    %% ПОМАРАНЧЕВЕ — освітлення
    BAT_O --> CLAR_O["Мінімальне освітлення<br>або без оклейки<br>самоосвітлення"]

    %% ══════ 20. СТАБІЛІЗАЦІЯ ══════

    %% БІЛЕ — стабілізація
    CLAR_W_SELF --> STAB_W["Холодна стабілізація:<br>-4°C протягом 5-10 днів<br>тартрати"]
    CLAR_W_BENT --> STAB_W
    CLAR_W_PVPP --> STAB_W
    CLAR_W_CAS --> STAB_W

    %% РОЖЕВЕ — стабілізація
    CLAR_ROSE_BENT --> STAB_ROSE["Холодна стабілізація:<br>-4°C протягом 5-10 днів<br>тартрати"]
    CLAR_ROSE_SELF --> STAB_ROSE

    %% ЧЕРВОНЕ — стабілізація
    CLAR_RED_EGG --> STAB_RED_COLD{"Холодна<br>стабілізація?"}
    CLAR_RED_GEL --> STAB_RED_COLD
    CLAR_RED_PVPP --> STAB_RED_COLD
    CLAR_RED_SKIP --> STAB_RED_COLD
    STAB_RED_COLD -- Так --> STAB_RED_C_YES["Холодна стабілізація:<br>-4°C протягом 5-10 днів"]
    STAB_RED_COLD -- Ні --> STAB_RED_C_NO["Без холодної стабілізації"]

    %% ПОМАРАНЧЕВЕ — стабілізація
    CLAR_O --> STAB_O["Мінімальна стабілізація<br>або без"]

    %% ══════ 21. ФІЛЬТРАЦІЯ ══════

    %% БІЛЕ
    STAB_W --> FILT_W["Фільтрація:<br>cross-flow або пластинчаста<br>0.45-1.0 мкм"]

    %% РОЖЕВЕ
    STAB_ROSE --> FILT_ROSE["Щільна фільтрація:<br>cross-flow або пластинчаста<br>0.45 мкм<br>зберегти колір і свіжість"]

    %% ЧЕРВОНЕ
    STAB_RED_C_YES --> FILT_RED{"Фільтрація?"}
    STAB_RED_C_NO --> FILT_RED
    FILT_RED -- Так --> FILT_RED_YES["Фільтрація:<br>пластинчаста 1-3 мкм<br>або cross-flow"]
    FILT_RED -- Ні --> FILT_RED_NO["Без фільтрації:<br>unfined / unfiltered"]

    %% ПОМАРАНЧЕВЕ
    STAB_O --> FILT_O{"Фільтрація?"}
    FILT_O -- Так --> FILT_O_YES["Делікатна фільтрація:<br>3-5 мкм"]
    FILT_O -- Ні --> FILT_O_NO["Без фільтрації"]

    %% ══════ 22А. РОЗЛИВ (СУХЕ) ══════
    FILT_W --> BOTTLING["Розлив"]
    FILT_ROSE --> BOTTLING
    FILT_RED_YES --> BOTTLING
    FILT_RED_NO --> BOTTLING
    FILT_O_YES --> BOTTLING
    FILT_O_NO --> BOTTLING

    %% ═══════════════════════════════════════════
    %% ══  ГІЛКА Б: ТИХЕ НЕ-СУХЕ ВИНО         ══
    %% ═══════════════════════════════════════════

    %% ══════ 15Б. МЛБ ДЛЯ НЕ-СУХИХ ══════
    NS_START --> NS_MLF_COLOR{"Сировина<br>і колір"}

    NS_MLF_COLOR -- Біле --> NS_MLF_NO_W["МЛБ: ні<br>блокувати SO2<br>зберегти кислотність<br>і залишковий цукор"]
    NS_MLF_COLOR -- "Блан де нуар" --> NS_MLF_NO_W
    NS_MLF_COLOR -- Рожеве --> NS_MLF_NO_ROSE["МЛБ: ні<br>блокувати SO2<br>зберегти свіжість"]

    NS_MLF_COLOR -- Червоне --> NS_MLF_RED{"Напівсухе<br>і танінність >= 50?"}
    NS_MLF_RED -- Так --> NS_MLF_RED_PART["МЛБ: часткове<br>зупинити після 50% конверсії<br>SO2 для блокування<br>пом'якшити танінну структуру"]
    NS_MLF_RED -- Ні --> NS_MLF_NO_RED["МЛБ: ні<br>блокувати SO2<br>зберегти кислотність"]

    NS_MLF_COLOR -- Помаранчеве --> NS_MLF_O{"Спонтанне МЛБ<br>вже почалось?"}
    NS_MLF_O -- Так --> NS_MLF_O_PART["Дозволити завершити<br>або зупинити SO2<br>контроль яблучної кислоти"]
    NS_MLF_O -- Ні --> NS_MLF_NO_O["МЛБ: ні<br>SO2 для блокування"]

    %% ══════ 16Б. ЗНЯТТЯ З ОСАДУ + SO2 (НЕ-СУХЕ) ══════
    NS_MLF_NO_W --> NS_RACK_SW{"Солодкість"}
    NS_MLF_NO_ROSE --> NS_RACK_SW
    NS_MLF_RED_PART --> NS_RACK_SW
    NS_MLF_NO_RED --> NS_RACK_SW
    NS_MLF_O_PART --> NS_RACK_SW
    NS_MLF_NO_O --> NS_RACK_SW

    NS_RACK_SW -- Напівсухе --> NS_RACK_SD["Зняття з осаду:<br>SO2 35-50 мг/л вільного"]
    NS_RACK_SW -- Напівсолодке --> NS_RACK_SS["Зняття з осаду:<br>SO2 40-60 мг/л вільного"]
    NS_RACK_SW -- Солодке --> NS_RACK_SWEET["Зняття з осаду:<br>SO2 50-80 мг/л вільного"]

    %% ══════ 17Б. ВИТРИМКА (НЕ-СУХЕ) ══════

    NS_RACK_SD --> NS_AGE_COLOR{"Сировина<br>і колір"}
    NS_RACK_SS --> NS_AGE_COLOR
    NS_RACK_SWEET --> NS_AGE_COLOR

    %% БІЛЕ / РОЖЕВЕ / БЛАН ДЕ НУАР — сталь
    NS_AGE_COLOR -- Біле --> NS_AGE_W["Витримка: сталь<br>1-4 місяці<br>зберегти свіжість і фруктовість"]
    NS_AGE_COLOR -- "Блан де нуар" --> NS_AGE_W
    NS_AGE_COLOR -- Рожеве --> NS_AGE_ROSE["Витримка: сталь<br>1-2 місяці<br>мінімальна витримка"]

    %% ЧЕРВОНЕ — сталь або короткий дуб
    NS_AGE_COLOR -- Червоне --> NS_AGE_RED{"Танінність >= 50<br>і напівсухе?"}
    NS_AGE_RED -- Так --> NS_AGE_RED_OAK["Витримка: б/в дуб<br>або великий дуб<br>3-6 місяців"]
    NS_AGE_RED -- Ні --> NS_AGE_RED_ST["Витримка: сталь<br>1-3 місяці"]

    %% ПОМАРАНЧЕВЕ — амфора або сталь
    NS_AGE_COLOR -- Помаранчеве --> NS_AGE_O{"Oxidation >= 50?"}
    NS_AGE_O -- Так --> NS_AGE_O_AMPH["Витримка: амфора<br>або великий дуб<br>2-6 місяців"]
    NS_AGE_O -- Ні --> NS_AGE_O_ST["Витримка: сталь<br>1-3 місяці"]

    %% ══════ 18Б. СТАБІЛІЗАЦІЯ ЗАЛИШКОВОГО ЦУКРУ ══════

    NS_AGE_W --> NS_STAB_RS{"Метод стабілізації RS"}
    NS_AGE_ROSE --> NS_STAB_RS
    NS_AGE_RED_OAK --> NS_STAB_RS
    NS_AGE_RED_ST --> NS_STAB_RS
    NS_AGE_O_AMPH --> NS_STAB_RS
    NS_AGE_O_ST --> NS_STAB_RS

    NS_STAB_RS -- "Сорбінова кислота + SO2" --> NS_SORB["Сорбінова кислота:<br>150-200 мг/л<br>+ SO2 вільний >= 30 мг/л<br>блокує повторне бродіння"]
    NS_STAB_RS -- "Стерильна фільтрація" --> NS_STERILE_ONLY["Без сорбінової кислоти:<br>стерильна фільтрація 0.45 мкм<br>забезпечить мікробну стабільність"]
    NS_STAB_RS -- "Обидва методи" --> NS_BOTH["Сорбінова кислота 150-200 мг/л<br>+ стерильна фільтрація<br>максимальна стабільність"]

    %% ══════ 19Б. ОСВІТЛЕННЯ (НЕ-СУХЕ) ══════

    NS_SORB --> NS_CLAR_COLOR{"Сировина<br>і колір"}
    NS_STERILE_ONLY --> NS_CLAR_COLOR
    NS_BOTH --> NS_CLAR_COLOR

    NS_CLAR_COLOR -- Біле --> NS_CLAR_W["Бентоніт:<br>20-50 г/гл<br>освітлення + білкова стабілізація"]
    NS_CLAR_COLOR -- "Блан де нуар" --> NS_CLAR_W
    NS_CLAR_COLOR -- Рожеве --> NS_CLAR_ROSE["Бентоніт:<br>20-40 г/гл<br>освітлення + білкова стабілізація"]
    NS_CLAR_COLOR -- Червоне --> NS_CLAR_RED{"Оклейка<br>потрібна?"}
    NS_CLAR_RED -- Так --> NS_CLAR_RED_GEL["Желатин 5-10 г/гл<br>або казеїн 5-15 г/гл"]
    NS_CLAR_RED -- Ні --> NS_CLAR_RED_SELF["Самоосвітлення:<br>відстоювання"]
    NS_CLAR_COLOR -- Помаранчеве --> NS_CLAR_O["Мінімальне освітлення<br>або без"]

    %% ══════ 20Б. СТАБІЛІЗАЦІЯ (НЕ-СУХЕ) ══════

    NS_CLAR_W --> NS_COLD["Холодна стабілізація:<br>-4°C протягом 5-10 днів<br>тартрати"]
    NS_CLAR_ROSE --> NS_COLD
    NS_CLAR_RED_GEL --> NS_COLD
    NS_CLAR_RED_SELF --> NS_COLD
    NS_CLAR_O --> NS_COLD

    %% ══════ 21Б. ФІЛЬТРАЦІЯ (НЕ-СУХЕ) ══════

    NS_COLD --> NS_FILT_ROUTE{"Сировина<br>і колір"}

    NS_FILT_ROUTE -- Біле --> NS_FILT["Стерильна фільтрація:<br>cross-flow або мембранна<br>0.45 мкм<br>обов'язкова для RS стабільності"]
    NS_FILT_ROUTE -- "Блан де нуар" --> NS_FILT
    NS_FILT_ROUTE -- Рожеве --> NS_FILT
    NS_FILT_ROUTE -- Червоне --> NS_FILT_RED_NS{"Фільтрація?"}
    NS_FILT_ROUTE -- Помаранчеве --> NS_FILT_O_NS{"Фільтрація?"}

    NS_FILT_RED_NS -- Так --> NS_FILT_RED["Фільтрація:<br>пластинчаста 0.45-1.0 мкм"]
    NS_FILT_RED_NS -- Ні --> NS_FILT_RED_NO["Без фільтрації:<br>лише якщо стабілізовано<br>сорбіновою кислотою + SO2"]

    NS_FILT_O_NS -- Так --> NS_FILT_O_DONE["Делікатна фільтрація:<br>1.0-3.0 мкм"]
    NS_FILT_O_NS -- Ні --> NS_FILT_O_DONE_NO["Без фільтрації:<br>лише якщо стабілізовано<br>сорбіновою кислотою + SO2"]

    %% ══════ 22Б. РОЗЛИВ (НЕ-СУХЕ) ══════
    NS_FILT --> BOTTLING
    NS_FILT_RED --> BOTTLING
    NS_FILT_RED_NO --> BOTTLING
    NS_FILT_O_DONE --> BOTTLING
    NS_FILT_O_DONE_NO --> BOTTLING

    %% ═══════════════════════════════════════════
    %% ══  ГІЛКА В: ІГРИСТЕ ВИНО               ══
    %% ═══════════════════════════════════════════

    %% ══════ 15В. ВИБІР МЕТОДУ ══════
    SPARK_METHOD -- Шампенуаз --> CHAMP_START["Méthode Traditionnelle"]
    SPARK_METHOD -- Трансфер --> TRANS_ENTRY["Transfer method"]
    SPARK_METHOD -- Шарма --> CHARMAT_START["Méthode Charmat"]
    SPARK_METHOD -- "Пет-нат" --> PETNAT_START["Méthode Ancestrale"]

    %% ══════════════════════════════════════════════════
    %% ШАМПЕНУАЗ + ТРАНСФЕР — спільні кроки 1-6
    %% ══════════════════════════════════════════════════

    %% 16В-1. МЛБ БАЗОВОГО ВИНА
    CHAMP_START --> CT_MLF{"МЛБ?"}
    TRANS_ENTRY --> CT_MLF

    CT_MLF -- Так --> CT_MLF_YES["МЛБ: так<br>інокуляція Oenococcus oeni<br>температура 18-22°C<br>складність, м'якість кислотності"]
    CT_MLF -- Ні --> CT_MLF_NO["МЛБ: ні<br>зберегти кислотність<br>SO2 після АБ"]
    CT_MLF -- Часткове --> CT_MLF_PART["МЛБ: часткове<br>зупинити після 30-50% конверсії<br>баланс кислотності і складності"]

    %% 16В-2. АССАМБЛЯЖ
    CT_MLF_YES --> CT_ASSEM{"Ассамбляж"}
    CT_MLF_NO --> CT_ASSEM
    CT_MLF_PART --> CT_ASSEM

    CT_ASSEM -- Моновінтаж --> CT_ASSEM_MONO["Моновінтажне базове вино<br>один урожай"]
    CT_ASSEM -- Мультивінтаж --> CT_ASSEM_MULTI["Мультивінтажний купаж<br>резервні вина різних років<br>стабільність стилю"]
    CT_ASSEM -- "Моносорт" --> CT_ASSEM_VAR["Моносортове базове вино"]
    CT_ASSEM -- "Купаж сортів" --> CT_ASSEM_BLEND["Купаж сортів<br>складність, баланс"]

    %% 17В. ОСВІТЛЕННЯ БАЗОВОГО ВИНА
    CT_ASSEM_MONO --> CT_CLAR["Освітлення базового вина:<br>бентоніт 20-40 г/гл<br>холодна стабілізація -4°C<br>фільтрація 0.45-1.0 мкм"]
    CT_ASSEM_MULTI --> CT_CLAR
    CT_ASSEM_VAR --> CT_CLAR
    CT_ASSEM_BLEND --> CT_CLAR

    %% 18В. ТИРАЖ
    CT_CLAR --> CT_TIRAGE["Тираж #40;liqueur de tirage#41;:<br>цукор 20-24 г/л<br>дріжджі для вторинного бродіння<br>бентоніт #40;для ремюажу#41;<br>розлив у пляшки з кронен-пробкою"]

    %% 18В-2. ВТОРИННЕ БРОДІННЯ В ПЛЯШЦІ
    CT_TIRAGE --> CT_PRISE["Prise de mousse:<br>вторинне бродіння в пляшці<br>температура 12-14°C<br>тривалість 6-8 тижнів<br>цільовий тиск 5-6 атм"]

    %% 18В-3. ВИТРИМКА НА ОСАДІ
    CT_PRISE --> CT_AGING{"Рівень<br>витримки"}
    CT_AGING -- Базовий --> CT_AGE_BASE["Витримка sur lie:<br>мінімум 12 місяців<br>автоліз дріжджів"]
    CT_AGING -- Вінтаж --> CT_AGE_VINT["Витримка sur lie:<br>мінімум 36 місяців<br>глибокий автоліз"]
    CT_AGING -- Престиж --> CT_AGE_PREST["Витримка sur lie:<br>60+ місяців<br>максимальна складність"]

    %% РОЗГАЛУЖЕННЯ: ШАМПЕНУАЗ vs ТРАНСФЕР
    CT_AGE_BASE --> CT_SPLIT{"Метод<br>виробництва"}
    CT_AGE_VINT --> CT_SPLIT
    CT_AGE_PREST --> CT_SPLIT

    %% ══════════════════════════════════════════════════
    %% ШАМПЕНУАЗ — кроки 7-10
    %% ══════════════════════════════════════════════════

    CT_SPLIT -- Шампенуаз --> CT_REM{"Ремюаж<br>#40;remuage#41;"}
    CT_REM -- Механічний --> CT_REM_MECH["Жиропалет:<br>3-7 днів<br>автоматичне обертання"]
    CT_REM -- Ручний --> CT_REM_HAND["Пюпітр:<br>6-8 тижнів<br>щоденне повертання вручну"]

    CT_REM_MECH --> CT_DEG["Дегоржаж:<br>заморозити горлечко -25°C<br>видалити крижану пробку з осадом<br>долити SO2 за потреби"]
    CT_REM_HAND --> CT_DEG

    CT_DEG --> DOSAGE

    %% ══════════════════════════════════════════════════
    %% ТРАНСФЕР — кроки 7-10
    %% ══════════════════════════════════════════════════

    CT_SPLIT -- Трансфер --> TR_TANK["Перелив під тиском:<br>вміст пляшок у герметичний танк<br>зберегти CO2"]
    TR_TANK --> TR_FILT["Фільтрація під тиском:<br>ізобарична фільтрація<br>видалення осаду"]
    TR_FILT --> DOSAGE

    %% ══════════════════════════════════════════════════
    %% ШАРМА (CHARMAT)
    %% ══════════════════════════════════════════════════

    %% 16В. МЛБ
    CHARMAT_START --> CH_MLF{"Ароматичне<br>вино?"}
    CH_MLF -- Так --> CH_MLF_NO["МЛБ: ні<br>зберегти ароматику і свіжість"]
    CH_MLF -- Ні --> CH_MLF_OPT{"МЛБ?"}
    CH_MLF_OPT -- Так --> CH_MLF_YES["МЛБ: так<br>інокуляція<br>температура 18-22°C"]
    CH_MLF_OPT -- Ні --> CH_MLF_SKIP["МЛБ: ні"]

    %% 17В. ОСВІТЛЕННЯ БАЗОВОГО ВИНА
    CH_MLF_NO --> CH_CLAR["Освітлення базового вина:<br>бентоніт 20-40 г/гл<br>фільтрація"]
    CH_MLF_YES --> CH_CLAR
    CH_MLF_SKIP --> CH_CLAR

    %% 18В. АВТОКЛАВ + ВТОРИННЕ БРОДІННЯ
    CH_CLAR --> CH_TANK["Перенос в автоклав<br>#40;герметичний танк#41;"]
    CH_TANK --> CH_TIRAGE["Liqueur de tirage:<br>цукор 20-24 г/л<br>дріжджі"]
    CH_TIRAGE --> CH_TYPE{"Тип Шарма"}
    CH_TYPE -- "Короткий Шарма" --> CH_SHORT["Вторинне бродіння в танку:<br>12-16°C<br>2-4 тижні<br>фруктовість, свіжість"]
    CH_TYPE -- "Довгий Шарма" --> CH_LONG["Вторинне бродіння в танку:<br>12-14°C<br>3-6 місяців<br>автоліз, складність"]

    %% ОХОЛОДЖЕННЯ + ФІЛЬТРАЦІЯ
    CH_SHORT --> CH_COOL["Охолодження:<br>зупинка бродіння<br>за потреби"]
    CH_LONG --> CH_COOL
    CH_COOL --> CH_FILT["Фільтрація під тиском:<br>ізобарична фільтрація<br>видалення осаду"]
    CH_FILT --> DOSAGE

    %% ══════════════════════════════════════════════════
    %% ПЕТ-НАТ (MÉTHODE ANCESTRALE)
    %% ══════════════════════════════════════════════════

    PETNAT_START --> PN_NOTE["Примітка: вино мало бути<br>розлите в пляшки під час<br>первинного бродіння<br>при SG 1.010-1.020"]
    PN_NOTE --> PN_FERM["Завершення бродіння в пляшці:<br>температура 12-16°C<br>тиск 2-3 атм<br>природна газація"]
    PN_FERM --> PN_DEG{"Дегоржаж?"}
    PN_DEG -- Так --> PN_DEG_YES["Дегоржаж:<br>заморозити горлечко<br>видалити осад<br>прозоре вино"]
    PN_DEG -- Ні --> PN_DEG_NO["Без дегоржажу:<br>каламутне, натуральне<br>осад залишається"]
    PN_DEG_YES --> PN_CORK["Закорковування<br>без дозажу"]
    PN_DEG_NO --> PN_CORK
    PN_CORK --> BOTTLING

    %% ══════════════════════════════════════════════════
    %% 20В. ДОЗАЖ (спільний блок)
    %% ══════════════════════════════════════════════════

    DOSAGE{"Рівень дозажу<br>#40;liqueur d'expédition#41;"}

    DOSAGE -- "Brut Nature" --> DOS_BN["Brut Nature / Zero dosage:<br>0-3 г/л цукру"]
    DOSAGE -- "Extra Brut" --> DOS_EB["Extra Brut:<br>0-6 г/л цукру"]
    DOSAGE -- Brut --> DOS_BR["Brut:<br>0-12 г/л цукру"]
    DOSAGE -- "Extra Dry" --> DOS_ED["Extra Dry:<br>12-17 г/л цукру"]
    DOSAGE -- Sec --> DOS_SEC["Sec:<br>17-32 г/л цукру"]
    DOSAGE -- "Demi-Sec" --> DOS_DS["Demi-Sec:<br>32-50 г/л цукру"]
    DOSAGE -- Doux --> DOS_DX["Doux:<br>50+ г/л цукру"]

    %% 21В. ФІНАЛЬНЕ ЗАКОРКОВУВАННЯ
    DOS_BN --> SPARK_CORK["Закорковування:<br>коркова пробка + мюзле<br>витримка після дозажу 1-3 міс"]
    DOS_EB --> SPARK_CORK
    DOS_BR --> SPARK_CORK
    DOS_ED --> SPARK_CORK
    DOS_SEC --> SPARK_CORK
    DOS_DS --> SPARK_CORK
    DOS_DX --> SPARK_CORK

    SPARK_CORK --> BOTTLING
