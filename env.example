# SendGrid Email Configuration
# Get your API key from: https://app.sendgrid.com/settings/api_keys
#
# Locally: sendgrid.env next to app.py (export KEY='value' lines; see sendgrid_env.py).
# Server: systemd EnvironmentFile = KEY=value without "export".
# SENDER_EMAIL must be verified in SendGrid (Settings → Sender Authentication).

SENDGRID_API_KEY=SG.your-api-key-here
SENDER_EMAIL=your-verified-email@example.com

# Setup instructions: See SENDGRID_SETUP.md
